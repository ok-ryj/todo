generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Todo {
  id        Int      @id @default(autoincrement())
  text      String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DailyItem {
  id            Int      @id @default(autoincrement())
  text          String
  completedDate String?
  createdAt     DateTime @default(now())
}
